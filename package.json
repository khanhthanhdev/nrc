{
  "name": "nrc-full",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.1",
      "typescript": "^6.0.2",
      "@types/bun": "^1.3.11",
      "hono": "^4.12.11",
      "@orpc/server": "^1.13.13",
      "@orpc/openapi": "^1.13.13",
      "@orpc/valibot": "^1.13.13",
      "valibot": "^1.3.1",
      "i18next": "^25.0.1",
      "vitest": "^4.1.2",
      "@vitest/ui": "^4.1.2",
      "@vitest/coverage-v8": "^4.1.2",
      "jsdom": "^29.0.1",
      "@playwright/test": "^1.59.1",
      "playwright": "^1.59.1",
      "@orpc/client": "^1.13.13"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:native": "turbo run dev --filter=native",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=server",
    "db:push": "turbo run db:push --filter=@nrc-full/db",
    "db:studio": "turbo run db:studio --filter=@nrc-full/db",
    "db:generate": "turbo run db:generate --filter=@nrc-full/db",
    "db:migrate": "turbo run db:migrate --filter=@nrc-full/db",
    "db:start": "turbo run db:start --filter=@nrc-full/db",
    "db:watch": "turbo run db:watch --filter=@nrc-full/db",
    "db:stop": "turbo run db:stop --filter=@nrc-full/db",
    "db:down": "turbo run db:down --filter=@nrc-full/db",
    "test:unit": "NODE_ENV=test BETTER_AUTH_SECRET=test BETTER_AUTH_URL=http://localhost CORS_ORIGIN=http://localhost DATABASE_URL=postgresql://localhost/test GOOGLE_CLIENT_ID=test GOOGLE_CLIENT_SECRET=test bun x vitest run apps/server/src/auth/duplicate-email-policy.unit.test.ts packages/api/src/features/auth/schemas/onboarding.unit.test.ts",
    "test:e2e": "NODE_ENV=test BETTER_AUTH_SECRET=test BETTER_AUTH_URL=http://localhost CORS_ORIGIN=http://localhost DATABASE_URL=postgresql://localhost/test GOOGLE_CLIENT_ID=test GOOGLE_CLIENT_SECRET=test bun x vitest run packages/api/src/features/auth/presentation/auth-router.e2e.test.ts",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "devDependencies": {
    "@nrc-full/config": "workspace:*",
    "@types/bun": "catalog:",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "ultracite": "7.6.0"
  },
  "packageManager": "bun@1.3.10"
}
