{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@better-auth/drizzle-adapter": "^1.6.5",
    "@better-upload/server": "^3.0.17",
    "@nrc-full/api": "workspace:*",
    "@nrc-full/db": "workspace:*",
    "@nrc-full/env": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/valibot": "catalog:",
    "better-auth": "^1.6.5",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "evlog": "^2.13.0",
    "hono": "catalog:",
    "i18next": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@nrc-full/config": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/bun": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jsdom": "catalog:",
    "playwright": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
